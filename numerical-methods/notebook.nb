$CellContext`rk4Solve[$CellContext`f$, $CellContext`x0$$, {
           0., $CellContext`tMax$$}, $CellContext`h$$]; $CellContext`nd$ = 
         NDSolve[{
           Derivative[1][$CellContext`x][$CellContext`t] == $CellContext`f$[
              $CellContext`x[$CellContext`t], $CellContext`t], $CellContext`x[
             0] == $CellContext`x0$$}, $CellContext`x, {$CellContext`t, 
            0, $CellContext`tMax$$}]; $CellContext`ndFn = 
         ReplaceAll[$CellContext`x, 
           Part[$CellContext`nd$, 1]]; $CellContext`tg$ = 
