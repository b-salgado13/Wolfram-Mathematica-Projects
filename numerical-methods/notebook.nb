Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Solve", " ", "with", " ", "all", " ", "three", " ", "manual", " ", 
    "methods"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tEulerLog", ",", "eulerLog"}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"eulerSolve", "[", 
       RowBox[{"logisticF", ",", "x0Log", ",", "tSpanLog", ",", "hLog"}], 
       "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tHeunLog", ",", "heunLog"}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"heunSolve", "[", 
       RowBox[{"logisticF", ",", "x0Log", ",", "tSpanLog", ",", "hLog"}], 
       "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tRK4Log", ",", "rk4Log"}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"rk4Solve", "[", 
       RowBox[{"logisticF", ",", "x0Log", ",", "tSpanLog", ",", "hLog"}], 
       "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Built", "-", 
     RowBox[{"in", " ", "NDSolve"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tNDLog", ",", "ndLog"}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
           RowBox[{"logisticF", "[", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], ",", "t"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"x", "[", "0", "]"}], "==", "x0Log"}]}], "}"}], ",", "x", ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"tSpanLog", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"tSpanLog", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"MaxStepSize", "->", "hLog"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ndLogFn", "=", 
     RowBox[{"x", "/.", " ", 
      RowBox[{"ndLog", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"interpolating", " ", "function"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Exact", " ", "reference", " ", "on", " ", "same", " ", "grid"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tGridLog", "=", 
     RowBox[{"eulerLog", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"exactLog", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"#", ",", 
         RowBox[{"logisticExact", "[", "#", "]"}]}], "}"}], "&"}], "/@", 
      "tGridLog"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Error", " ", "analysis"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Max", " ", "absolute", " ", "error", " ", "vs", " ", "closed"}],
      "-", 
     RowBox[{"form", " ", "solution"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errEulerLog", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"eulerLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", 
        RowBox[{"exactLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"errHeunLog", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"heunLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", 
        RowBox[{"exactLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errRK4Log", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"rk4Log", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", 
        RowBox[{"exactLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"errNDLog", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ndLogFn", "/@", "tGridLog"}], ")"}], "-", 
        RowBox[{"exactLog", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"errTable", "=", 
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Method\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Max |Error|\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Timing (s)\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Result P[8]\>\"", ",", "Bold", ",", "12"}], "]"}]}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<Euler\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errEulerLog", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tEulerLog", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"eulerLog", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<Euler\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errHeunLog", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tHeunLog", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"heunLog", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<RK4\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errRK4Log", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tRK4Log", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"rk4Log", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<NDSolve\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errNDLog", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tNDLog", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"ndLogFn", "/@", "tGridLog"}], ")"}], "[", 
              RowBox[{"[", 
               RowBox[{"-", "1"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"Frame", "->", "All"}], ",", 
       RowBox[{"Background", "->", 
        RowBox[{"{", 
         RowBox[{"None", ",", 
          RowBox[{"{", 
