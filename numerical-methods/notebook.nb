      Module[{$CellContext`f$, $CellContext`euler$, $CellContext`rk4$, \
$CellContext`ep$, $CellContext`pp$, $CellContext`rp$, $CellContext`rpp$, \
$CellContext`nd$, $CellContext`xNDf$, $CellContext`yNDf$}, $CellContext`f$ = 
         Function[{$CellContext`xy$, $CellContext`t$}, {$CellContext`a$$ 
             Part[$CellContext`xy$, 1] - $CellContext`b$$ 
            Part[$CellContext`xy$, 1] 
            Part[$CellContext`xy$, 2], $CellContext`d$$ 
             Part[$CellContext`xy$, 1] 
             Part[$CellContext`xy$, 2] - $CellContext`g$$ 
