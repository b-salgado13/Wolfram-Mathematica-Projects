Cell["Stefan\[CloseCurlyQuote]s Law", "Subtitle",
 CellFrame->{{5, 0}, {0, 0}},
 CellChangeTimes->{{3.98338456282423*^9, 3.9833845674600716`*^9}, {
  3.9833847300859337`*^9, 3.9833847362527466`*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"a274cbca-7e22-f34c-b03f-f63656d29be1"],

Cell[TextData[{
 "Following Stefan\[CloseCurlyQuote]s law for radiation, absolute temperature \
T of a given body, cooling in a medium with absolute constant temperature ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "m"], TraditionalForm]],ExpressionUUID->
  "3d6b2295-85c7-1741-a7bf-48b5917ff04d"],
 " is given by:\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["dT", "dt"], "=", 
    RowBox[{"k", "(", 
     RowBox[{
      SuperscriptBox["T", "4"], "-", 
      SuperscriptBox[
       SubscriptBox["T", "m"], "4"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"086bdbf6-d7b3-f545-b15a-412aa0b22cbf"],
 "\nwhere k is a proportionality constant dependent on the surface area, the \
emisivity of the material and the Stefan-Boltzmann constant. \nStefan\
\[CloseCurlyQuote]s law can be applied to a greater temperature range than \
Newton\[CloseCurlyQuote]s law for cooling bodies.\n\nFor this problem, \
suppose a hot body with initial conditions:\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "m"], TraditionalForm]],ExpressionUUID->
  "05aaccda-7639-0442-8df1-a58734dce265"],
 "=20 K (-253.15 \[Degree]C as medium constant)\nT[0]=300 K (26.85 \[Degree]C \
as initial body temperature)\nk=",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    SuperscriptBox["10", 
     RowBox[{"-", "7"}]]}], TraditionalForm]],ExpressionUUID->
  "156c5630-43ef-cc43-85fa-df3002a8deb4"],
 "\nTime is measured in minutes.\nWhat temperature will the body have after \
30 minutes?\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tT[30]=?\nSince this equation does \
not have an exact solution, solving with NDSolve method is set as the \
reference solution."
}], "Text",
 CellFrame->{{4, 0}, {0, 0}},
 CellChangeTimes->{
  3.9831021941063385`*^9, {3.9831039177422905`*^9, 3.9831042351264305`*^9}, {
   3.983357797907114*^9, 3.983357811635023*^9}, {3.983357856699135*^9, 
   3.98335788368178*^9}, {3.983359731795574*^9, 3.9833597449305687`*^9}, {
   3.983361787070179*^9, 3.9833617899120007`*^9}, {3.983367459917061*^9, 
   3.983367495369711*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"18cf3911-ded3-c642-aa2e-3439c0c902d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Tm", "=", "20"}], ";", 
  RowBox[{"k", "=", 
   RowBox[{"-", 
    SuperscriptBox["10", 
     RowBox[{"-", "7"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x0Temp", "=", "300"}], ";", 
  RowBox[{"tSpanTemp", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "30"}], "}"}]}], ";", 
  RowBox[{"hTemp", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TempF", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"k", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"x", "^", "4"}], "-", 
     RowBox[{"Tm", "^", "4"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Stefan's Law: dT/dt = \>\"", ",", "k", 
   ",", "\"\< (\!\(\*SuperscriptBox[\(T\), \(4\)]\)-\>\"", ",", "Tm", 
   ",", "\"\<\!\(\*SuperscriptBox[\(\), \(4\)]\))\>\""}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<T(0) = \>\"", ",", "x0Temp", ",", "\"\<,  t in \>\"", ",", 
   "tSpanTemp"}], "]"}]}], "Input",
 CellChangeTimes->{{3.983355948635067*^9, 3.9833559566006317`*^9}, {
   3.983356005397789*^9, 3.983356160810276*^9}, {3.9833562686990757`*^9, 
   3.9833562701916122`*^9}, {3.983356311114847*^9, 3.983356313759577*^9}, {
   3.983356354732189*^9, 3.9833563548507843`*^9}, {3.9833564310068016`*^9, 
   3.9833566040576897`*^9}, {3.9833567920728855`*^9, 3.983356792764078*^9}, {
   3.9833579098333054`*^9, 3.983357988287489*^9}, {3.983360484231201*^9, 
   3.9833604843370495`*^9}, 3.983361212829294*^9, {3.983368063019989*^9, 
   3.9833681626650963`*^9}, {3.9833682136322517`*^9, 3.983368213995962*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"b5a39564-de5f-804e-8fff-2040d4ac4a2f"],

