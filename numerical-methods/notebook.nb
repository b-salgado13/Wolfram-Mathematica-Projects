        RowBox[{"orange", ",", " ", "blue", ",", " ", "purple"}], "}"}]}], ",",
       "\n", "  ", 
      RowBox[{"PlotLegends", " ", "->", " ", 
       RowBox[{"LineLegend", "[", 
        RowBox[{
