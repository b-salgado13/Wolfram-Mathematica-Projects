Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Error", " ", "convergence", " ", "plot", "  ", 
    RowBox[{"(", 
     RowBox[{"how", " ", "error", " ", "scales", " ", "with", " ", "h"}], 
     ")"}]}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"hValues", " ", "=", " ", 
