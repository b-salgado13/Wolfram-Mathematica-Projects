       "0.02", ",", " ", "0.01"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"errorConvergence", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "eul", ",", "heunsol", ",", " ", "rk4sol", ",", " ", "exRef", ",", 
          " ", "tg"}], "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"eul", "    ", "=", " ", 
          RowBox[{"eulerSolve", "[", 
           RowBox[{
           "logisticF", ",", " ", "x0Log", ",", " ", "tSpanLog", ",", " ", 
            "h"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"heunsol", "=", " ", 
          RowBox[{"heunSolve", "[", 
           RowBox[{
           "logisticF", ",", " ", "x0Log", ",", " ", "tSpanLog", ",", " ", 
            "h"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"rk4sol", " ", "=", " ", 
          RowBox[{"rk4Solve", "[", 
           RowBox[{
           "logisticF", ",", "   ", "x0Log", ",", " ", "tSpanLog", ",", " ", 
            "h"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"tg", "     ", "=", " ", 
          RowBox[{"eul", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"exRef", "  ", "=", " ", 
          RowBox[{"logisticExact", " ", "/@", " ", "tg"}]}], ";", "\n", 
         "    ", 
         RowBox[{"{", 
          RowBox[{"h", ",", "\n", "     ", 
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"eul", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "2"}], "]"}], "]"}], "    ", "-", " ", 
              "exRef"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"heunsol", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "2"}], "]"}], "]"}], "    ", "-", " ", 
              "exRef"}], "]"}], "]"}], ",", "\n", "     ", 
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"rk4sol", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "2"}], "]"}], "]"}], " ", "-", " ", 
              "exRef"}], "]"}], "]"}]}], "}"}]}]}], "\n", "  ", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"h", ",", " ", "hValues"}], "}"}]}], "\n", "]"}]}], "\n", 
   RowBox[{"convergencePlot", " ", "=", " ", 
    RowBox[{"ListLogLogPlot", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"errorConvergence", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "]"}], ",", "\n", 
        "   ", 
        RowBox[{"errorConvergence", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}], "]"}], ",", 
