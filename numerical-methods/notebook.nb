         RowBox[{
          SubscriptBox["x", "n"], ",", 
          SubscriptBox["y", "n"]}], ")"}]}]}], ")"}]}], "2"], 
   TraditionalForm]], "Subsection",ExpressionUUID->
  "c85426e5-0213-6144-87f7-ee0e8b5703a1"],
 "\n- Fourth order Runge-Kutta method\n",
