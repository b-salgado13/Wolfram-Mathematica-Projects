Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Solving", " ", "the", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tEulerTemp", ",", " ", "eulerTemp"}], "}"}], "  ", "=", " ", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"eulerSolve", "[", 
       RowBox[{
       "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
        "hTemp"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tHeunTemp", ",", " ", "heunTemp"}], "}"}], "  ", "=", " ", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"heunSolve", "[", 
       RowBox[{
       "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
        "hTemp"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tRK4Temp", ",", "rk4Temp"}], "}"}], "=", " ", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"rk4Solve", "[", 
       RowBox[{
       "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
        "hTemp"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"NDSolve", " ", "reference"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tNDTemp", ",", "ndTemp"}], "}"}], "=", 
     RowBox[{"AbsoluteTiming", "[", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
           RowBox[{"TempF", "[", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], ",", "t"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"x", "[", "0", "]"}], "==", "x0Temp"}]}], "}"}], ",", "x", 
        ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"tSpanTemp", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{"tSpanTemp", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"interpolating", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ndTempFn", "=", 
     RowBox[{"x", "/.", " ", 
      RowBox[{"ndTemp", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Error", " ", "analysis"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Max", " ", "absolute", " ", "error", " ", "vs", " ", "reference", " ", 
     "solution"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ndTempGrid", "=", 
     RowBox[{"ndTempFn", "/@", 
      RowBox[{"eulerTemp", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errEulerTemp", " ", "=", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"eulerTemp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "-", 
        "ndTempGrid"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"errHeunTemp", " ", "=", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"heunTemp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "-", 
        "ndTempGrid"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errRK4Temp", " ", "=", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"rk4Temp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "   ", "-", 
        "ndTempGrid"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"errTable", "=", 
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Method\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Max |Error|\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Timing (s)\>\"", ",", "Bold", ",", "12"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Result T[30](K)\>\"", ",", "Bold", ",", "12"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<Euler\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errEulerTemp", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tEulerTemp", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"eulerTemp", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<Heun\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errHeunTemp", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tHeunTemp", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"heunTemp", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<RK4\>\"", ",", 
           RowBox[{"ScientificForm", "[", 
            RowBox[{"errRK4Temp", ",", "4"}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tRK4Temp", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"rk4Temp", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<NDSolve\>\"", ",", "\"\<Set as reference\>\"", ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{"tNDTemp", ",", 
             RowBox[{"{", 
              RowBox[{"5", ",", "6"}], "}"}]}], "]"}], ",", 
           RowBox[{"NumberForm", "[", 
            RowBox[{
             RowBox[{"ndTempGrid", "[", 
              RowBox[{"[", 
               RowBox[{"-", "1"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "}"}]}], "}"}], ",", 
       RowBox[{"Frame", "->", "All"}], ",", 
       RowBox[{"Background", "->", 
        RowBox[{"{", 
         RowBox[{"None", ",", 
          RowBox[{"{", 
           RowBox[{"DarkBlue", ",", "None", ",", "None", ",", "None"}], 
           "}"}]}], "}"}]}], ",", 
       RowBox[{"Spacings", "->", 
        RowBox[{"{", 
         RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
   "Print", "[", "\"\<=== Stefan's Law - Error & Timing ===\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "errTable", "]"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Solution", " ", "plot"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"logisticPlot", " ", "=", " ", 
    RowBox[{"Show", "[", " ", 
     RowBox[{
      RowBox[{"ListLinePlot", "[", 
       RowBox[{
