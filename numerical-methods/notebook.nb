Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Error", " ", "convergence", " ", "plot", "  ", 
    RowBox[{"(", 
     RowBox[{"how", " ", "error", " ", "scales", " ", "with", " ", "h"}], 
     ")"}]}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"hValues", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
      "0.4", ",", " ", "0.2", ",", " ", "0.1", ",", " ", "0.05", ",", " ", 
       "0.02", ",", " ", "0.01"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"errorConvergence", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"eul", ",", " ", "heunsol", ",", "rk4sol"}], "}"}], ",", 
         "\n", "    ", 
         RowBox[{
          RowBox[{"eul", "    ", "=", " ", 
           RowBox[{"eulerSolve", "[", 
            RowBox[{
            "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
             "h"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"heunsol", " ", "=", " ", 
           RowBox[{"heunSolve", "[", 
            RowBox[{
            "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
             "h"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"rk4sol", " ", "=", " ", 
           RowBox[{"rk4Solve", "[", 
            RowBox[{
            "TempF", ",", " ", "x0Temp", ",", " ", "tSpanTemp", ",", " ", 
             "h"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"h", ",", "\n", "     ", 
            RowBox[{"Max", "[", 
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"eul", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}], "-", 
               RowBox[{"ndTempGrid", "[", 
                RowBox[{"[", 
                 RowBox[{"-", "1"}], "]"}], "]"}]}], "]"}], "]"}], ",", "\n", 
            "     ", 
            RowBox[{"Max", "[", 
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"heunsol", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}], "-", 
               RowBox[{"ndTempGrid", "[", 
                RowBox[{"[", 
                 RowBox[{"-", "1"}], "]"}], "]"}]}], "]"}], "]"}], ",", "\n", 
            "     ", 
            RowBox[{"Max", "[", 
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"rk4sol", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}], "-", 
               RowBox[{"ndTempGrid", "[", 
                RowBox[{"[", 
                 RowBox[{"-", "1"}], "]"}], "]"}]}], "]"}], "]"}]}], 
           "}"}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"h", ",", " ", "hValues"}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"convergencePlot", " ", "=", " ", 
    RowBox[{"ListLogLogPlot", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"errorConvergence", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "]"}], ",", 
        RowBox[{"errorConvergence", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "3"}], "}"}]}], "]"}], "]"}], ",", 
        RowBox[{"errorConvergence", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "4"}], "}"}]}], "]"}], "]"}]}], "}"}], ",",
       "\n", "  ", 
      RowBox[{"Joined", " ", "->", " ", "True"}], ",", "\n", "  ", 
      RowBox[{"PlotMarkers", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"Automatic", ",", " ", "8"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"PlotStyle", "  ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"orange", ",", " ", "blue", ",", "green"}], "}"}]}], ",", 
      "\n", "  ", 
      RowBox[{"PlotLegends", " ", "->", " ", 
       RowBox[{"LineLegend", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"orange", ",", " ", "blue", ",", " ", "green"}], "}"}], ",",
          " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Euler (O(h))\>\"", ",", 
           " ", "\"\<Heun (O(\!\(\*SuperscriptBox[\(h\), \(2\)]\)))\>\"", ",",
            " ", "\"\<RK4 (O(\!\(\*SuperscriptBox[\(h\), \(4\)]\)))\>\""}], 
          "}"}], ",", "\n", "                             ", 
