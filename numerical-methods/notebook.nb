Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Logistic", " ", "Equation", " ", "Explorer"}], "*)"}], "\n", 
  RowBox[{"Manipulate", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "f", ",", " ", "exact", ",", " ", "euler", ",", "heun", ",", " ", 
        "rk4", ",", " ", "nd", ",", " ", "errE", ",", "errH", ",", " ", 
        "errR", ",", " ", "tg"}], "}"}], ",", "\n", "    ", 
      RowBox[{
       RowBox[{"f", "=", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"x", ",", " ", "t"}], "}"}], ",", " ", 
          RowBox[{"r", " ", "x", " ", 
           RowBox[{"(", 
            RowBox[{"1", " ", "-", " ", 
             RowBox[{"x", "/", "K"}]}], ")"}]}]}], "]"}]}], ";", "\n", "    ", 
       RowBox[{"exact", "=", 
        RowBox[{"Function", "[", 
         RowBox[{"tt", ",", " ", 
          RowBox[{"K", " ", "/", " ", 
           RowBox[{"(", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"K", " ", "-", " ", "x0"}], ")"}], "/", "x0"}], 
               ")"}], " ", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "r"}], " ", "tt"}], "]"}]}]}], ")"}]}]}], 
         "]"}]}], ";", "\n", "\n", "    ", 
       RowBox[{"euler", "=", 
        RowBox[{"eulerSolve", "[", 
         RowBox[{"f", ",", " ", "x0", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.0", ",", " ", "tMax"}], "}"}], ",", " ", "h"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"heun", "=", 
        RowBox[{"heunSolve", "[", 
         RowBox[{"f", ",", " ", "x0", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.0", ",", " ", "tMax"}], "}"}], ",", " ", "h"}], "]"}]}],
        ";", "\n", "    ", 
       RowBox[{"rk4", "=", 
        RowBox[{"rk4Solve", "[", 
         RowBox[{"f", ",", "   ", "x0", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0.0", ",", " ", "tMax"}], "}"}], ",", " ", "h"}], "]"}]}],
        ";", "\n", "\n", "    ", 
       RowBox[{"nd", "=", 
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"xN", "'"}], "[", "t", "]"}], " ", "==", " ", 
             RowBox[{"f", "[", 
              RowBox[{
               RowBox[{"xN", "[", "t", "]"}], ",", " ", "t"}], "]"}]}], ",", 
            " ", 
            RowBox[{
             RowBox[{"xN", "[", "0", "]"}], " ", "==", " ", "x0"}]}], "}"}], ",",
           "\n", "                 ", "xN", ",", " ", 
          RowBox[{"{", 
           RowBox[{"t", ",", " ", "0", ",", " ", "tMax"}], "}"}], ",", " ", 
          RowBox[{"MaxStepSize", " ", "->", " ", "h"}]}], "]"}]}], ";", "\n", 
       "    ", 
       RowBox[{"ndFn", "=", 
        RowBox[{"xN", " ", "/.", " ", 
         RowBox[{"nd", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "\n", "    ", 
       RowBox[{"tg", "=", 
        RowBox[{"euler", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], ";", "\n", "    ", 
       RowBox[{"errE", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"euler", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "-", " ", 
           RowBox[{"exact", " ", "/@", " ", "tg"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"errH", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"heun", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "-", " ", 
           RowBox[{"exact", " ", "/@", " ", "tg"}]}], "]"}], "]"}]}], ";", 
       "\n", "    ", 
       RowBox[{"errR", "  ", "=", " ", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"rk4", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "   ", "-", " ", 
           RowBox[{"exact", " ", "/@", " ", "tg"}]}], "]"}], "]"}]}], ";", 
       "\n", "\n", "    ", 
       RowBox[{"Column", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Show", "[", "\n", "        ", 
            RowBox[{
             RowBox[{"ListLinePlot", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"euler", ",", "heun", ",", " ", "rk4"}], "}"}], ",", 
               " ", 
               RowBox[{"Joined", " ", "->", " ", "True"}], ",", "\n", 
               "          ", 
               RowBox[{"PlotStyle", " ", "->", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"Directive", "[", 
                   RowBox[{"orange", ",", " ", "Dashed", ",", " ", "Thick"}], 
                   "]"}], ",", "\n", "                        ", 
                  RowBox[{"Directive", "[", 
                   RowBox[{"blue", ",", "   ", "Dashed", ",", " ", "Thick"}], 
                   "]"}], ",", "\[IndentingNewLine]", 
                  RowBox[{"Directive", "[", 
                   RowBox[{
                   "purple", ",", "   ", "Dashed", ",", " ", "Thick"}], 
                   "]"}]}], "}"}]}], ",", "\n", "          ", 
               RowBox[{"PlotRange", " ", "->", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"0", ",", " ", "tMax"}], "}"}], ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", " ", 
                    RowBox[{"K", " ", "*", " ", "1.1"}]}], "}"}]}], "}"}]}], ",",
                "\n", "          ", 
               RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
               RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", "\n", 
               "          ", 
               RowBox[{"FrameLabel", " ", "->", " ", 
                RowBox[{"{", 
                 RowBox[{"\"\<t\>\"", ",", "\"\<x(t)\>\""}], "}"}]}], ",", 
               "\n", "          ", 
               RowBox[{"PlotLabel", " ", "->", " ", 
                RowBox[{"Style", "[", 
                 
                 RowBox[{"\"\<Logistic Equation\>\"", ",", " ", "14", ",", 
                  " ", "Bold"}], "]"}]}], ",", "\[IndentingNewLine]", " ", 
               RowBox[{"ImageSize", "->", "Medium"}]}], "\n", "        ", 
              "]"}], ",", "\n", "        ", 
             RowBox[{"Plot", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"exact", "[", "t", "]"}], ",", " ", 
                 RowBox[{"ndFn", "[", "t", "]"}]}], "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"t", ",", " ", "0", ",", " ", "tMax"}], "}"}], ",", 
               "\n", "          ", 
               RowBox[{"PlotStyle", " ", "->", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"Directive", "[", 
                   RowBox[{"green", ",", " ", "Thick"}], "]"}], ",", "\n", 
                  "                        ", 
                  RowBox[{"Directive", "[", 
                   RowBox[{"red", ",", " ", "Dotted", ",", " ", "Thick"}], 
                   "]"}]}], "}"}]}]}], "]"}], ",", "\n", "        ", 
             RowBox[{"PlotLegend", " ", "->", " ", "None"}]}], "\n", "      ",
             "]"}], ",", "\n", "      ", 
           RowBox[{"Grid", "[", 
            RowBox[{
             RowBox[{"{", "\n", "        ", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Style", "[", 
                  RowBox[{"\"\<Euler max|err|\>\"", ",", " ", "Bold"}], "]"}],
                  ",", " ", 
                 RowBox[{"ScientificForm", "[", 
                  RowBox[{"errE", ",", " ", "4"}], "]"}]}], "}"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Style", "[", 
                  RowBox[{"\"\<Heun  max|err|\>\"", ",", " ", "Bold"}], "]"}],
                  ",", " ", 
                 RowBox[{"ScientificForm", "[", 
                  RowBox[{"errH", ",", " ", "4"}], "]"}]}], "}"}], ",", "\n", 
               "        ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Style", "[", 
                  RowBox[{"\"\<RK4   max|err|\>\"", ",", " ", "Bold"}], "]"}],
