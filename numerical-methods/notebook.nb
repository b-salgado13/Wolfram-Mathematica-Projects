 "+h ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["y", "n"]}], ")"}], "+", 
     RowBox[{"f", "(", 
      RowBox[{
       SubscriptBox["x", 
