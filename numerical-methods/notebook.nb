$CellContext`eulerSolve[$CellContext`f$, {$CellContext`x0$$, \
$CellContext`y0$$}, {
           0., $CellContext`tEnd$$}, $CellContext`h$$]; $CellContext`rk4$ = \
$CellContext`rk4Solve[$CellContext`f$, {$CellContext`x0$$, \
