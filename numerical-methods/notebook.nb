           "}"}]}], "}"}]}], ",", 
       RowBox[{"Spacings", "->", 
        RowBox[{"{", 
         RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<=== Logistic Equation \[LongDash] Error & Timing \
===\>\"", "]"}], "\n", 
