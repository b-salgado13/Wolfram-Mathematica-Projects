             RowBox[{"{", 
              
              RowBox[{"\"\<Euler\>\"", ",", " ", "\"\<Heun\>\"", ",", 
               " ", "\"\<RK4\>\"", ",", " ", "\"\<Reference\>\""}], "}"}], ",", 
             RowBox[{"LegendMarkerSize", " ", "->", " ", "25"}]}], "]"}], ",",
            "\n", "      ", 
           RowBox[{"{", 
