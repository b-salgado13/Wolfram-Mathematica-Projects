Cell[CellGroupData[{

Cell["Logistic Equation", "Subtitle",
 CellFrame->{{5, 0}, {0, 0}},
 CellChangeTimes->{{3.98338456282423*^9, 3.9833845674600716`*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"697af78d-ab45-3541-890c-d3ce0ff6a74e"],

Cell[TextData[{
 "A mathematical model used to describe population growth that account for \
limited resources is formulated through the logistic equation:\n\t\t\t\t\t\t\t\
\t\t\t\t\t\t\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["dP", "dt"], "=", 
    RowBox[{"rP", "(", 
     RowBox[{"1", "-", 
      FractionBox["P", "K"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5ea9bcc3-1118-8143-8646-015acdf93e2c"],
 "\nwhere P is the pullulation, r is the growth rate and K is the carrying \
capacity.\n\nFor this problem, suppose the initial conditions:\nr = 1.5   \
(growth rate)\nK = 10.0;  (carrying capacity)\nP[0] = 0.5;  (initial \
population)\nWhat will be the population after 8 time units?\n\t\t\t\t\t\t\t\t\
\t\t\t\t\t\t\tT[8]=?"
}], "Text",
 CellFrame->{{4, 0}, {0, 0}},
 CellChangeTimes->{
  3.9831021941063385`*^9, {3.9831039177422905`*^9, 3.9831042351264305`*^9}, {
   3.983357797907114*^9, 3.983357811635023*^9}, {3.983357856699135*^9, 
   3.98335788368178*^9}, {3.983359731795574*^9, 3.9833597449305687`*^9}, {
   3.983361787070179*^9, 3.9833617899120007`*^9}, {3.983367459917061*^9, 
   3.983367495369711*^9}, {3.983367706636141*^9, 3.9833678313830566`*^9}, {
   3.983367896976219*^9, 3.9833680190412426`*^9}, 3.9833683573439713`*^9, {
   3.983384515980995*^9, 3.9833845334625473`*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"a2a12f30-315f-5d46-aff6-499e7e4ec87a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Parameters", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rLog", "=", "1.5"}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"growth", " ", "rate"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"KLog", "=", "10.0"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"carrying", " ", "capacity"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"x0Log", "=", "0.5"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"initial", " ", "population"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"tSpanLog", "=", 
     RowBox[{"{", 
      RowBox[{"0.0", ",", "8.0"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hLog", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"RHS", " ", "function"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"logisticF", "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
    RowBox[{"rLog", "*", "x", "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"x", "/", "KLog"}]}], ")"}]}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Exact", " ", 
     RowBox[{"(", 
      RowBox[{"closed", "-", "form"}], ")"}], " ", "solution"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"logisticExact", "[", "t_", "]"}], ":=", 
    RowBox[{"KLog", "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"KLog", "-", "x0Log"}], ")"}], "/", "x0Log"}], ")"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "rLog"}], " ", "t"}], "]"}]}]}], ")"}]}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Logistic equation: dx/dt = \>\"", ",", "rLog", 
     ",", "\"\< x (1 - x/\>\"", ",", "KLog", ",", "\"\<)\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<x(0) = \>\"", ",", "x0Log", ",", "\"\<,  t in \>\"", ",", 
     "tSpanLog"}], "]"}]}]}]], "Input",
