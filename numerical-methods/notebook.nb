Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Euler", " ", "Step"}], "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Forward", " ", "Euler"}], " ", "\[LongDash]", " ", 
    RowBox[{"first", "-", "order"}], ",", " ", 
    RowBox[{"O", 
     RowBox[{"(", "h", ")"}], " ", "local", " ", "error"}]}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"eulerStep", "[", 
     RowBox[{"f_", ",", " ", "x_", ",", " ", "t_", ",", " ", "h_"}], "]"}], 
    " ", ":=", " ", 
    RowBox[{"x", " ", "+", " ", 
     RowBox[{"h", " ", "*", " ", 
      RowBox[{"f", "[", 
       RowBox[{"x", ",", " ", "t"}], "]"}]}]}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Improved", " ", "Euler", " ", "Step"}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Heun", "'"}], "s", " ", 
      RowBox[{"method", "/", "Improved"}], " ", "Euler"}], " ", "\[LongDash]",
      " ", 
     RowBox[{"second", "-", "order"}], ",", " ", 
     RowBox[{"O", 
      RowBox[{"(", 
       SuperscriptBox["h", "2"], ")"}], " ", "local", " ", "error"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"heunStep", "[", 
     RowBox[{"f_", ",", " ", "x_", ",", " ", "t_", ",", " ", "h_"}], "]"}], 
    " ", ":=", " ", 
    RowBox[{"x", " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"h", "/", "2"}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"x", ",", " ", "t"}], "]"}], "+", " ", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"x", "+", 
           RowBox[{"h", "*", 
            RowBox[{"f", "[", 
             RowBox[{"x", ",", "t"}], "]"}]}]}], ",", 
          RowBox[{"t", "+", " ", 
           RowBox[{"h", "/", "2"}]}]}], " ", "]"}]}], ")"}]}]}]}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Runge", "-", 
     RowBox[{"Kutta", " ", "4", " ", "Step"}]}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Classical", " ", "RK4"}], " ", "\[LongDash]", " ", 
     RowBox[{"fourth", "-", "order"}], ",", " ", 
     RowBox[{"O", 
      RowBox[{"(", 
       FormBox[
        SuperscriptBox["h", "4"],
        TraditionalForm], ")"}], " ", "local", " ", "error"}]}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"rk4Step", "[", 
     RowBox[{"f_", ",", " ", "x_", ",", " ", "t_", ",", " ", "h_"}], "]"}], 
    " ", ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"k1", ",", " ", "k2", ",", " ", "k3", ",", " ", "k4"}], "}"}], 
      ",", "\n", "    ", 
      RowBox[{
       RowBox[{"k1", " ", "=", " ", 
        RowBox[{"f", "[", 
         RowBox[{"x", ",", "t"}], "]"}]}], ";", "\n", "    ", 
       RowBox[{"k2", " ", "=", " ", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"x", " ", "+", " ", 
           RowBox[{"h", " ", 
            RowBox[{"k1", "/", "2"}]}]}], ",", "  ", 
          RowBox[{"t", " ", "+", " ", 
           RowBox[{"h", "/", "2"}]}]}], " ", "]"}]}], ";", "\n", "    ", 
       RowBox[{"k3", " ", "=", " ", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"x", " ", "+", " ", 
           RowBox[{"h", " ", 
            RowBox[{"k2", "/", "2"}]}]}], ",", "  ", 
          RowBox[{"t", " ", "+", " ", 
           RowBox[{"h", "/", "2"}]}]}], " ", "]"}]}], ";", "\n", "    ", 
       RowBox[{"k4", " ", "=", " ", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{"x", " ", "+", " ", 
           RowBox[{"h", " ", "k3"}]}], ",", "    ", 
          RowBox[{"t", " ", "+", " ", "h"}]}], "   ", "]"}]}], ";", "\n", 
       "    ", 
       RowBox[{"x", " ", "+", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"h", "/", "6"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"k1", " ", "+", " ", 
           RowBox[{"2", " ", "k2"}], " ", "+", " ", 
           RowBox[{"2", " ", "k3"}], " ", "+", " ", "k4"}], ")"}]}]}]}]}], 
     "\n", "  ", "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Generic", " ", 
     RowBox[{"driver", ":", " ", 
      RowBox[{
      "applies", " ", "stepFn", " ", "repeatedly", " ", "over", " ", "a", " ",
        "uniform", " ", "grid"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"integrate", "[", 
     RowBox[{"stepFn_", ",", " ", "f_", ",", " ", "x0_", ",", " ", 
      RowBox[{"{", 
       RowBox[{"t0_", ",", " ", "t1_"}], "}"}], ",", " ", "h_"}], "]"}], " ", 
    ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"tGrid", ",", " ", "xs", ",", " ", "x"}], "}"}], ",", "\n", 
      "    ", 
      RowBox[{
       RowBox[{"tGrid", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"t0", ",", " ", "t1", ",", " ", "h"}], "]"}]}], ";", "\n", 
       "    ", 
       RowBox[{"x", " ", "=", " ", "x0"}], ";", "\n", "    ", 
       RowBox[{"xs", " ", "=", " ", 
        RowBox[{
         RowBox[{"Reap", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"Sow", "[", 
            RowBox[{"{", 
             RowBox[{"t0", ",", " ", "x"}], "}"}], "]"}], ";", "\n", "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"x", " ", "=", " ", 
               RowBox[{"stepFn", "[", 
                RowBox[{"f", ",", " ", "x", ",", " ", 
                 RowBox[{"tGrid", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], ",", " ", "h"}], "]"}]}], ";",
               "\n", "        ", 
              RowBox[{"Sow", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"tGrid", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", " ", "+", " ", "1"}], "]"}], "]"}], ",", " ", 
                 "x"}], "}"}], "]"}]}], ",", "\n", "        ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "1", ",", " ", 
               RowBox[{
                RowBox[{"Length", "[", "tGrid", "]"}], " ", "-", " ", "1"}]}],
               "}"}]}], "]"}]}], "\n", "    ", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", " ", "1"}], "]"}], "]"}]}], ";", "\n", "    ", 
       "xs"}]}], "\n", "  ", "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"eulerSolve", "[", 
     RowBox[{"f_", ",", " ", "x0_", ",", " ", "tSpan_", ",", " ", "h_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{"integrate", "[", 
     RowBox[{
     "eulerStep", ",", " ", "f", ",", " ", "x0", ",", " ", "tSpan", ",", " ", 
      "h"}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"heunSolve", "[", 
     RowBox[{"f_", ",", " ", "x0_", ",", " ", "tSpan_", ",", " ", "h_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{"integrate", "[", 
     RowBox[{
     "heunStep", ",", " ", "f", ",", " ", "x0", ",", " ", "tSpan", ",", " ", 
      "h"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rk4Solve", "[", 
     RowBox[{"f_", ",", "   ", "x0_", ",", " ", "tSpan_", ",", " ", "h_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{"integrate", "[", 
     RowBox[{
     "rk4Step", ",", "   ", "f", ",", " ", "x0", ",", " ", "tSpan", ",", " ", 
      "h"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.983353229246935*^9, 3.9833533222754784`*^9}, {
   3.983354889206623*^9, 3.983354937297819*^9}, {3.983354994826565*^9, 
