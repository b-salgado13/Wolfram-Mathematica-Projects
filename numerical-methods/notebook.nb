Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Performance", " ", "check"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Run", " ", "each", " ", "method", " ", "multiple", " ", "times", " ", 
    "for", " ", "stable", " ", "timing"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nRuns", "=", "5"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"timingLog", "=", 
     RowBox[{"<|", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Euler\>\"", "->", 
        RowBox[{"Mean", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"AbsoluteTiming", "[", 
             RowBox[{"eulerSolve", "[", 
              RowBox[{
              "logisticF", ",", "x0Log", ",", "tSpanLog", ",", "0.01"}], 
              "]"}], "]"}]}], ",", "nRuns"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<Heun\>\"", "->", 
        RowBox[{"Mean", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"AbsoluteTiming", "[", 
             RowBox[{"heunSolve", "[", 
              RowBox[{
              "logisticF", ",", "x0Log", ",", "tSpanLog", ",", "0.01"}], 
              "]"}], "]"}]}], ",", "nRuns"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<RK4\>\"", "->", 
        RowBox[{"Mean", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"AbsoluteTiming", "[", 
             RowBox[{"rk4Solve", "[", 
              RowBox[{
              "logisticF", ",", "x0Log", ",", "tSpanLog", ",", "0.01"}], 
              "]"}], "]"}]}], ",", "nRuns"}], "]"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<NDSolve\>\"", "->", 
        RowBox[{"Mean", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
             RowBox[{"NDSolve", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"x", "'"}], "[", "t", "]"}], "==", 
                  RowBox[{"logisticF", "[", 
                   RowBox[{
                    RowBox[{"x", "[", "t", "]"}], ",", "t"}], "]"}]}], ",", 
                 RowBox[{
                  RowBox[{"x", "[", "0", "]"}], "==", "x0Log"}]}], "}"}], ",",
                "x", ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"t", ",", "0", ",", "8"}], "}"}], ",", 
               RowBox[{"MaxStepSize", "->", "0.01"}]}], "]"}], "]"}]}], ",", 
           "nRuns"}], "]"}]}]}]}], "\[IndentingNewLine]", "|>"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"timingTemp", "=", 
     RowBox[{"<|", "\[IndentingNewLine]", 
