      "\n", "  ", 
      RowBox[{"FrameLabel", "  ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<Step size h\>\"", ",", " ", "\"\<Max |Error|\>\""}], 
        "}"}]}], ",", 
      RowBox[{"PlotLabel", "  ", "->", " ", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Error Convergence vs Step Size\>\"", ",", " ", "14", ",",
          " ", "Bold"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"GridLines", "  ", "->", " ", "Automatic"}], ",", 
